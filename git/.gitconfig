[user]
    name = zryyyy
    email = 37234999+zryyyy@users.noreply.github.com

[core]
    autocrlf = input
    eol = lf
    whitespace = blank-at-eol,blank-at-eof,space-before-tab

[push]
    autoSetupRemote = true

[pull]
    rebase = true

[fetch]
    prune = true

[help]
    autocorrect = prompt

[branch]
    sort = -committerdate


# [includeIf "hasconfig:remote.*.url:**gitlab.com/**"]
#     path = ~/.dotfiles/git/.gitconfig-gitlab

[include]
    path = ~/.gitconfig-local
